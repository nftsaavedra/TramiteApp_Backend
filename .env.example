DATABASE_URL="postgresql://user:password@localhost:5432/tramite_db?schema=public"
JWT_SECRET="super-secret-key-change-in-production"
JWT_EXPIRES_IN="1d"
ROOT_OFFICE_SIGLAS="VPIN"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="adminPassword123"
PORT=3000
CORS_ORIGIN="http://localhost:5173"

# ============================================
# PERFORMANCE OPTIMIZATIONS (Opcional)
# ============================================

# Redis para caché (SOLO cuando escales a múltiples instancias)
# POR AHORA: No es necesario. El caché en memoria funciona perfectamente.
# Cuando tengas load balancing con 2+ servidores, descomenta esto:
# REDIS_URL="redis://localhost:6379"

# Rate Limiting (protección contra abuso)
THROTTLE_TTL=60          # Tiempo de vida en segundos
THROTTLE_LIMIT=10        # Peticiones por TTL