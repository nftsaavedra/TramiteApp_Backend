# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/tramites_db?schema=public"

# Puerto del servidor
PORT=3000

# CORS - Orígenes permitidos (separados por coma)
# Desarrollo: URLs de Vite dev server
# Producción: URL del dominio principal
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000

# JWT Configuration
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<GENERAR_SECRET_SEGURO_AQUI>
JWT_EXPIRES_IN=1d

# NOTA IMPORTANTE DE SEGURIDAD:
# 1. NUNCA commitear este archivo con valores reales
# 2. Copiar a .env y completar con valores específicos del entorno
# 3. Las credenciales de administrador se generan automáticamente en el primer inicio
# 4. Rotar JWT_SECRET regularmente y después de cualquier incidente de seguridad
# 5. En producción, usar variables de entorno del sistema o servicios de secrets management
